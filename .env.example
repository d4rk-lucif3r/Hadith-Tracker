# Hadith Tracker Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (send a message to your bot, then visit:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates to find your chat_id)
TELEGRAM_CHAT_ID=your_chat_id_here

# Path to your hadith-tracker data directory (absolute path)
DB_DIR=/path/to/hadith-tracker/data

# Timezone (IANA timezone string, e.g. America/New_York, Europe/London, Asia/Dubai)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York
